{
  "name": "@philosoph/modules",
  "version": "0.1.0",
  "description": "The stock question modules. Plugins: they depend on the module API, and nothing depends on them except an application composing a registry.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@philosoph/module-api": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "keywords": [
    "philosoph-question-modules"
  ]
}
